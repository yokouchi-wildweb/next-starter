{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/features/adminCommand/*": ["./src/features/core/adminCommand/*"],
      "@/features/analytics/*": ["./src/features/core/analytics/*"],
      "@/features/auditLog/*": ["./src/features/core/auditLog/*"],
      "@/features/auth/*": ["./src/features/core/auth/*"],
      "@/features/coupon/*": ["./src/features/core/coupon/*"],
      "@/features/couponHistory/*": ["./src/features/core/couponHistory/*"],
      "@/features/insane/*": ["./src/features/core/insane/*"],
      "@/features/mail/*": ["./src/features/core/mail/*"],
      "@/features/milestone/*": ["./src/features/core/milestone/*"],
      "@/features/notification/*": ["./src/features/core/notification/*"],
      "@/features/notificationTemplate/*": ["./src/features/core/notificationTemplate/*"],
      "@/features/purchaseRequest/*": ["./src/features/core/purchaseRequest/*"],
      "@/features/rateLimit/*": ["./src/features/core/rateLimit/*"],
      "@/features/referral/*": ["./src/features/core/referral/*"],
      "@/features/referralReward/*": ["./src/features/core/referralReward/*"],
      "@/features/setting/*": ["./src/features/core/setting/*"],
      "@/features/user/*": ["./src/features/core/user/*"],
      "@/features/userProfile/*": ["./src/features/core/userProfile/*"],
      "@/features/userLineProfile/*": ["./src/features/core/userLineProfile/*"],
      "@/features/userXProfile/*": ["./src/features/core/userXProfile/*"],
      "@/features/userTag/*": ["./src/features/core/userTag/*"],
      "@/features/wallet/*": ["./src/features/core/wallet/*"],
      "@/features/chatRoom/*": ["./src/features/core/chatRoom/*"],
      "@/features/walletHistory/*": ["./src/features/core/walletHistory/*"],
      "@/features/batchJob/*": ["./src/features/core/batchJob/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/_stash",
    "src/features/_template",
    "src/app/admin/_template",
    "TODO.md"
  ]
}
