
APP_ENV=development
PORT=3000

# アプリのベースURL（決済コールバック・メール内リンク等で使用）
# - 未設定時は src/config/business.config.ts の businessConfig.url を使用
# - Vercel preview デプロイでは VERCEL_URL を自動検出するため未設定で動作
# - dev:        APP_BASE_URL=http://localhost:3000
# - ngrok 経由: APP_BASE_URL=https://xxxxxxxx.ngrok-free.app
# - staging:    APP_BASE_URL=https://staging.example.com
APP_BASE_URL=https://next-starter-wildweb.vercel.app/

# 画像最適化 (next/image)
# enabled にすると Next/Vercel の画像最適化（リサイズ・WebP変換・srcset）が有効になります
# ※ Vercel では画像最適化が従量課金のため、既定は無効。有効化はプロジェクトごとの明示的な選択です
# ※ 効果が及ぶのは next/image を使う表示のみ（raw <img> は影響なし）
# ※ 外部画像の許可リストは自プロジェクトの Firebase Storage バケットに自動限定されます（next.config.ts 参照）
# IMAGE_OPTIMIZATION=enabled

# 認証セッション用 JWT シークレット（任意の文字列に変更）
AUTH_JWT_SECRET=xT9!jvR6q3ZbW2p@E4sMhY0LdNfQ8uKt
# 出力ログのレベル（0 = 出力なし、3 = 最大）
NEXT_PUBLIC_LOG_LEVEL=3

# Drizzle / Neon 等の DB 接続文字列
DATABASE_URL=''

# DB調査エージェント用の読取専用接続文字列 (任意)
# 未設定なら /api/admin/db-agent は無効 (fail-closed)。
# 読取専用ロールの作成手順: src/lib/dbAgent/README.md
DATABASE_URL_READONLY=''

# Firebase (ブラウザ SDK 共通設定)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin 用サービスアカウント JSON
# ※ リモートメディアをブラウザで読む機能(動画のMSE連結再生 / fetch読み取り / <video crossOrigin>→canvas / Web Audio)を使う場合、
#    Storage バケットに CORS 設定が必要(バケット単位・一度きり)。手順: pnpm storage:setup-cors
#    詳細: docs/how-to/initial-setup/StorageのCORS設定（リモートメディア読み取りの基盤前提）.md
MY_SERVICE_ACCOUNT_KEY=''

# reCAPTCHA（https://www.google.com/recaptcha/admin/create）
# 未設定の場合は reCAPTCHA 検証がスキップされます
# v3: スコアベースの自動判定
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=
# v2: チャレンジベースの手動認証（v3で中間スコアの場合に使用）
NEXT_PUBLIC_RECAPTCHA_V2_SITE_KEY=
RECAPTCHA_V2_SECRET_KEY=

# メール送信設定
# プロバイダー選択: resend（デフォルト） または sendgrid
# 未設定の場合は resend が使用されます
MAIL_PROVIDER=resend
# Resend（https://resend.com）
RESEND_API_KEY=
# SendGrid（https://sendgrid.com）
# MAIL_PROVIDER=sendgrid に設定した場合に必要
SENDGRID_API_KEY=

# Microsoft Clarity（空の場合は無効化）
NEXT_PUBLIC_MICROSOFT_CLARITY_ID=

# Google tag (gtag.js) / Google Ads（すべて空なら完全無効化＝no-op）
# GA4 測定ID（G-XXXXXXX）。未設定なら gtag.js を読み込まない
NEXT_PUBLIC_GOOGLE_TAG_ID=
# Google Ads ID（AW-XXXXXXX）。未設定なら Ads の config をスキップ
NEXT_PUBLIC_GOOGLE_ADS_ID=
# コンバージョン send_to（"AW-XXXXXXX/label" 形式）。未設定なら該当コンバージョンは no-op
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_SIGNUP=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_COIN_PURCHASE=

# Claude API
ANTHROPIC_API_KEY=

# GMO Fincode 設定
# テスト環境: https://api.test.fincode.jp
# 本番環境: https://api.fincode.jp
FINCODE_API_URL=
FINCODE_SECRET_KEY=
FINCODE_PUBLIC_KEY=
FINCODE_WEBHOOK_SIGNATURE=

# Square 設定
# sandbox: テスト環境 / production: 本番環境
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_SIGNATURE_KEY=
SQUARE_NOTIFICATION_URL=

# Stripe 設定（Stripe Checkout リダイレクト方式）
# ダッシュボード: https://dashboard.stripe.com/
# テスト環境はダッシュボード左上のトグルで切り替え
# シークレットキー（[開発者] → [APIキー]）
# テスト: sk_test_... / 本番: sk_live_...
STRIPE_SECRET_KEY=
# Webhook 署名シークレット（whsec_...）
# ローカル開発: `stripe listen --forward-to localhost:3000/api/webhook/payment` 実行時に表示される値
# 本番/ステージング: [開発者] → [Webhook] でエンドポイント登録後に発行される値
STRIPE_WEBHOOK_SECRET=

# Paidy 設定（client_sdk 起動方式 / paidy.js）
# ダッシュボード: https://new-merchant.paidy.com/settings
# パブリックキー（pk_test_... / pk_live_...）。クライアント (paidy.js) に渡される
PAIDY_PUBLIC_KEY=
# シークレットキー（sk_test_... / sk_live_...）。サーバー側で Paidy API 呼び出しに使用
# 発行時に一度しか全表示されないため、必ずコピーして保管すること
PAIDY_SECRET_KEY=

# PayPal 設定（client_sdk 起動方式 / PayPal JS SDK ボタン・直接連携）
# ダッシュボード: https://developer.paypal.com/dashboard/
# 実行環境: sandbox（開発・疎通確認） / live（本番）。sandbox と live で API ホストが異なるため必須。
PAYPAL_ENV=sandbox
# クライアント ID。クライアント JS SDK に渡される公開値（sandbox キーなら自動で sandbox 動作）
PAYPAL_CLIENT_ID=
# シークレット。サーバー側で Orders API / Webhook 検証に使用
PAYPAL_CLIENT_SECRET=
# Webhook ID。署名検証（verify-webhook-signature API）に使用。
# ダッシュボードで Webhook URL（/api/webhook/payment?provider=paypal）を登録すると発行される
PAYPAL_WEBHOOK_ID=

# LINE連携設定
# LINE Login チャネル（OAuth + LIFF）
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# LINE Messaging API チャネル（Push通知・Webhook）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=
# LIFF アプリID（LINE内ブラウザ用、任意）
LIFF_ID=

# X (Twitter) 連携設定
# OAuth 2.0 PKCE（ユーザー認証フロー）
# X Developer Portal → Project → App → Keys and tokens から取得
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
# OAuth 1.0a（メディアアップロード・アプリ公式アカウント投稿に必要）
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# トークン暗号化キー（AES-256-GCM、64文字の hex）
# generateEncryptionKey() で生成するか、以下で生成:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
