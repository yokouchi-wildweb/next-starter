{
  "domainConfigVersion": "1.2",
  "singular": "notification_template",
  "plural": "notification_templates",
  "label": "お知らせテンプレート",
  "dbEngine": "Neon",
  "idType": "uuid",
  "relations": [],
  "useCreatedAt": true,
  "useUpdatedAt": true,
  "fields": [
    {
      "name": "name",
      "label": "管理用名称",
      "fieldType": "string",
      "formInput": "textInput",
      "required": true
    },
    {
      "name": "title",
      "label": "タイトル",
      "fieldType": "string",
      "formInput": "textInput",
      "required": true,
      "placeholder": "{{variableName}} で変数を埋め込めます"
    },
    {
      "name": "body",
      "label": "本文",
      "fieldType": "string",
      "formInput": "textarea",
      "required": true,
      "placeholder": "{{variableName}} で変数を埋め込めます"
    },
    {
      "name": "variables",
      "label": "変数定義",
      "fieldType": "jsonb",
      "formInput": "custom",
      "required": false
    },
    {
      "name": "category",
      "label": "カテゴリ",
      "fieldType": "enum",
      "formInput": "select",
      "required": true,
      "options": [
        { "value": "system", "label": "システム" },
        { "value": "manual", "label": "手動" }
      ]
    }
  ],
  "searchFields": ["name", "title"],
  "defaultOrderBy": [["updatedAt", "DESC"]],
  "tableFields": ["name", "title", "category", "updatedAt"],
  "": false,
  "generateFiles": {
    "entities": true,
    "components": true,
    "hooks": true,
    "clientServices": true,
    "serverServices": true,
    "adminRoutes": true,
    "registry": true,
    "fieldConstants": true,
    "presenters": true
  }
}
